# ============================================================
# CraeSync AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=development           # development | production
SECRET_KEY=change-me-use-a-64-char-random-string-in-production

# ── Database (PostgreSQL) ─────────────────────────────────────
POSTGRES_DB=gesturemed
POSTGRES_USER=gesturemed
POSTGRES_PASSWORD=gesturemed_secret
# Full async URL (used by backend)
DATABASE_URL=postgresql+asyncpg://gesturemed:gesturemed_secret@postgres:5432/gesturemed

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI Providers (at least one required for report generation) ─
# Provider to use: "gemini"
AI_PROVIDER=gemini
AI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...           # Optional fallback

# ── JWT Auth ──────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=52428800         # 50MB in bytes

# ── RAG (V2) — free/local only, no paid API required ──────────
QDRANT_URL=http://qdrant:6333
OLLAMA_URL=http://ollama:11434
RAG_ENABLE_PUBMED=true
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── GPU / ROCm (V2) ────────────────────────────────────────────
GPU_ENABLED=true
GPU_BACKEND=auto                 # auto | rocm | cuda | cpu
GPU_MEMORY_FRACTION=0.9
OLLAMA_FALLBACK_MODEL=llama3.2:latest

# ── Frontend (Next.js) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Production overrides (uncomment for prod) ─────────────────
# ENVIRONMENT=production
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
# CORS_ORIGINS=https://yourdomain.com
